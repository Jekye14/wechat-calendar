/* app.wxss */
page {
  background: #f5f5f5;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
}

.container {
  padding: 0 24rpx;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* 状态徽章 */
.badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}
.badge-pending  { background: #FFF3CD; color: #856404; }
.badge-approved { background: #D4EDDA; color: #155724; }
.badge-rejected { background: #F8D7DA; color: #721C24; }
.badge-assigned { background: #CCE5FF; color: #004085; }

/* 按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
}
.btn-primary { background: #4A90D9; color: #fff; }
.btn-danger  { background: #E53935; color: #fff; }
.btn-outline {
  background: transparent;
  color: #4A90D9;
  border: 2rpx solid #4A90D9;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 80rpx 0;
  color: #bbb;
  font-size: 28rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 20rpx 0;
}
