.page { padding-bottom: 40rpx; background: #f5f5f5; min-height: 100vh; }
.header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 32rpx 24rpx 20rpx; background: #4A90D9;
}
.header-left { display: flex; align-items: center; }
.avatar { width: 72rpx; height: 72rpx; border-radius: 50%; margin-right: 16rpx; background: #fff; }
.welcome { color: #fff; font-size: 30rpx; font-weight: 500; }
.header-btn {
  background: rgba(255,255,255,0.25); color: #fff;
  padding: 12rpx 24rpx; border-radius: 30rpx; font-size: 26rpx;
}
.section-title { padding: 28rpx 24rpx 12rpx; font-size: 26rpx; color: #999; font-weight: 500; }
.cal-list { padding: 0 16rpx; }
.cal-card {
  display: flex; align-items: center; background: #fff;
  border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.cal-icon {
  width: 80rpx; height: 80rpx; border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 40rpx; font-weight: bold; flex-shrink: 0;
}
.cal-info { flex: 1; margin: 0 20rpx; }
.cal-name { font-size: 32rpx; font-weight: 600; color: #222; margin-bottom: 8rpx; }
.cal-desc { font-size: 24rpx; color: #888; margin-bottom: 12rpx; }
.cal-meta { display: flex; align-items: center; gap: 12rpx; }
.role-tag { font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 20rpx; }
.role-creator { background: #E3F0FD; color: #1565C0; }
.role-member  { background: #E8F5E9; color: #2E7D32; }
.cal-date { font-size: 22rpx; color: #bbb; }
.arrow { font-size: 36rpx; color: #ccc; }
.empty { text-align: center; padding: 100rpx 0; color: #bbb; font-size: 28rpx; }
.modal-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,0.5);
  display: flex; align-items: center; justify-content: center; z-index: 100;
}
.modal { background: #fff; border-radius: 24rpx; width: 620rpx; padding: 40rpx; }
.modal-title { font-size: 36rpx; font-weight: 700; text-align: center; margin-bottom: 32rpx; }
.field { margin-bottom: 24rpx; }
.field-label { font-size: 26rpx; color: #666; margin-bottom: 10rpx; display: block; }
.field-input {
  border: 2rpx solid #e0e0e0; border-radius: 10rpx;
  padding: 16rpx 20rpx; font-size: 28rpx; width: 100%; box-sizing: border-box;
}
.field-textarea {
  border: 2rpx solid #e0e0e0; border-radius: 10rpx;
  padding: 16rpx 20rpx; font-size: 28rpx; width: 100%; height: 120rpx; box-sizing: border-box;
}
.modal-btns { display: flex; gap: 20rpx; margin-top: 12rpx; }
.modal-btn {
  flex: 1; height: 88rpx; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center; font-size: 30rpx;
}
.cancel { background: #f5f5f5; color: #666; }
.confirm { background: #4A90D9; color: #fff; }
