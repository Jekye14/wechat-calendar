<!-- pages/notification/notification.wxml -->
<view class="page">
  <view class="nav-title">通知中心</view>
  <view wx:if="{{loading}}" class="empty">加载中...</view>
  <view wx:elif="{{notifications.length===0}}" class="empty">
    <text>暂无通知</text>
  </view>
  <view wx:else class="notif-list">
    <view
      class="notif-item {{item.is_read?'read':'unread'}}"
      wx:for="{{notifications}}" wx:key="id"
      bindtap="goToEvent"
      data-cal-id="{{item.ref_cal_id}}"
      data-event-id="{{item.ref_event_id}}"
    >
      <view class="notif-icon type-{{item.type}}">
        <text wx:if="{{item.type=='new_event'}}">📋</text>
        <text wx:elif="{{item.type=='approved'}}">✅</text>
        <text wx:elif="{{item.type=='rejected'}}">❌</text>
        <text wx:elif="{{item.type=='assigned'}}">📌</text>
        <text wx:else>🔔</text>
      </view>
      <view class="notif-body">
        <view class="notif-title">{{item.title}}</view>
        <view class="notif-content">{{item.content}}</view>
        <view class="notif-time">{{item.created_at}}</view>
      </view>
      <view wx:if="{{!item.is_read}}" class="unread-dot"></view>
    </view>
  </view>
</view>
