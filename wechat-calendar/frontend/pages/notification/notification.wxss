.page { background: #f5f5f5; min-height: 100vh; }
.nav-title {
  background: #4A90D9; color: #fff; font-size: 36rpx; font-weight: 700;
  padding: 32rpx 24rpx 24rpx; text-align: center;
}
.notif-list { padding: 16rpx; }
.notif-item {
  display: flex; align-items: flex-start;
  background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); position: relative;
}
.notif-item.read { opacity: 0.65; }
.notif-icon {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; flex-shrink: 0; margin-right: 20rpx;
}
.type-new_event { background: #E3F0FD; }
.type-approved  { background: #E8F5E9; }
.type-rejected  { background: #FFEBEE; }
.type-assigned  { background: #E8EAF6; }
.notif-body { flex: 1; }
.notif-title { font-size: 30rpx; font-weight: 600; color: #222; margin-bottom: 8rpx; }
.notif-content { font-size: 26rpx; color: #666; line-height: 1.5; margin-bottom: 8rpx; }
.notif-time { font-size: 22rpx; color: #bbb; }
.unread-dot {
  position: absolute; top: 20rpx; right: 20rpx;
  width: 16rpx; height: 16rpx; border-radius: 50%; background: #E53935;
}
.empty { text-align: center; padding: 120rpx 0; color: #bbb; font-size: 28rpx; }
