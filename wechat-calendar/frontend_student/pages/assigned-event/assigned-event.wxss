.page { padding: 24rpx; background: #f5f5f5; min-height: 100vh; }
.form-card {
  background: #fff; border-radius: 16rpx; padding: 0 24rpx; margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.field { padding: 24rpx 0; }
.label { font-size: 28rpx; color: #333; font-weight: 500; display: block; margin-bottom: 16rpx; }
.label.required::after { content: ' *'; color: #E53935; }
.input {
  font-size: 28rpx; color: #222; background: #f8f8f8;
  border-radius: 10rpx; padding: 16rpx 20rpx; width: 100%; box-sizing: border-box;
}
.textarea {
  font-size: 28rpx; color: #222; background: #f8f8f8;
  border-radius: 10rpx; padding: 16rpx 20rpx; width: 100%; box-sizing: border-box; height: 120rpx;
}
.divider { height: 1rpx; background: #f5f5f5; }
.datetime-row { display: flex; gap: 16rpx; }
.picker-box {
  flex: 1; background: #f8f8f8; border-radius: 10rpx;
  padding: 16rpx 20rpx; font-size: 28rpx; color: #222; text-align: center;
}
.section-title { font-size: 26rpx; color: #666; font-weight: 600; padding: 0 8rpx 12rpx; }
.member-card {
  background: #fff; border-radius: 16rpx; padding: 0 24rpx; margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.member-item {
  display: flex; align-items: center; padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.member-item:last-child { border-bottom: none; }
.member-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; background: #eee; margin-right: 16rpx; }
.member-name { flex: 1; font-size: 30rpx; color: #333; }
.check {
  width: 48rpx; height: 48rpx; border-radius: 50%; border: 2rpx solid #ddd;
  display: flex; align-items: center; justify-content: center; color: #fff; font-size: 24rpx;
}
.check.checked { background: #4A90D9; border-color: #4A90D9; }
.tip { font-size: 24rpx; color: #999; padding: 0 8rpx 24rpx; line-height: 1.6; }
.submit-btn {
  background: #5C6BC0; color: #fff; height: 96rpx; border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: 600;
}
.submit-btn.disabled { background: #B0BEC5; }
.empty { text-align: center; padding: 60rpx; color: #bbb; font-size: 28rpx; }
