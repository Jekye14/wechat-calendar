.page { background: #f5f5f5; min-height: 100vh; padding-bottom: 40rpx; }
.status-banner {
  padding: 20rpx 32rpx; font-size: 28rpx; font-weight: 600; text-align: center;
}
.status-pending  { background: #FFF3CD; color: #856404; }
.status-approved { background: #D4EDDA; color: #155724; }
.status-rejected { background: #F8D7DA; color: #721C24; }
.status-assigned { background: #CCE5FF; color: #004085; }
.card {
  background: #fff; margin: 16rpx; border-radius: 16rpx; padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.event-title { font-size: 40rpx; font-weight: 700; color: #222; margin-bottom: 24rpx; }
.info-row { display: flex; align-items: flex-start; margin-bottom: 16rpx; }
.icon { font-size: 32rpx; margin-right: 16rpx; flex-shrink: 0; }
.info-val { font-size: 28rpx; color: #444; flex: 1; line-height: 1.6; }
.arrow { color: #aaa; }
.section-label { font-size: 26rpx; color: #999; margin-bottom: 16rpx; }
.assignee-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.assignee-item { display: flex; align-items: center; gap: 10rpx; }
.assignee-avatar { width: 56rpx; height: 56rpx; border-radius: 50%; background: #eee; }
.action-card {
  background: #fff; margin: 16rpx; border-radius: 16rpx; padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.action-title { font-size: 26rpx; color: #999; margin-bottom: 16rpx; }
.action-row { display: flex; gap: 16rpx; }
.btn-approve {
  flex: 1; height: 88rpx; background: #4CAF50; color: #fff;
  border-radius: 12rpx; display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; font-weight: 600;
}
.btn-reject {
  flex: 1; height: 88rpx; background: #F44336; color: #fff;
  border-radius: 12rpx; display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; font-weight: 600;
}
.btn-outline {
  height: 88rpx; border: 2rpx solid #4A90D9; color: #4A90D9;
  border-radius: 12rpx; display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; margin-bottom: 16rpx;
}
.btn-danger-outline {
  height: 88rpx; border: 2rpx solid #E53935; color: #E53935;
  border-radius: 12rpx; display: flex; align-items: center; justify-content: center;
  font-size: 30rpx;
}
.empty { text-align: center; padding: 100rpx; color: #bbb; }
.modal-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,0.5);
  display: flex; align-items: center; justify-content: center; z-index: 100;
}
.modal { background: #fff; border-radius: 24rpx; width: 620rpx; padding: 40rpx; }
.modal-title { font-size: 34rpx; font-weight: 700; text-align: center; margin-bottom: 24rpx; }
.reject-input {
  border: 2rpx solid #e0e0e0; border-radius: 10rpx;
  padding: 16rpx; font-size: 28rpx; width: 100%; height: 160rpx; box-sizing: border-box;
}
.modal-btns { display: flex; gap: 20rpx; margin-top: 20rpx; }
.modal-btn {
  flex: 1; height: 88rpx; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center; font-size: 30rpx;
}
.cancel { background: #f5f5f5; color: #666; }
.reject { background: #E53935; color: #fff; }
