<view class="page">
  <view wx:if="{{status=='loading'}}" class="center">
    <view class="loader"></view>
    <text class="hint">正在加入日历...</text>
  </view>

  <view wx:elif="{{status=='success'}}" class="center">
    <text class="big-icon">🎉</text>
    <view class="result-title">{{message}}</view>
    <view class="result-cal">「{{calendarName}}」</view>
    <view class="btn primary" bindtap="goCalendar">进入日历</view>
    <view class="btn outline" bindtap="goHome">返回首页</view>
  </view>

  <view wx:elif="{{status=='error'}}" class="center">
    <text class="big-icon">😕</text>
    <view class="result-title">{{message}}</view>
    <view class="btn outline" bindtap="goHome">返回首页</view>
  </view>
</view>
