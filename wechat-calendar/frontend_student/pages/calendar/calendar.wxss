/* pages/calendar/calendar.wxss */
.page { background: #f0f2f5; min-height: 100vh; display: flex; flex-direction: column; }

/* ── Tab ── */
.tabs { display: flex; background: #fff; border-bottom: 2rpx solid #f0f0f0; flex-shrink: 0; }
.tab { flex: 1; text-align: center; padding: 28rpx 0; font-size: 28rpx; color: #888; }
.tab.active { color: #4A90D9; border-bottom: 4rpx solid #4A90D9; font-weight: 600; }

/* ── 周导航 ── */
.week-nav {
  display: flex; align-items: center; justify-content: space-between;
  background: #fff; padding: 16rpx 8rpx; flex-shrink: 0;
  border-bottom: 1rpx solid #eee;
}
.nav-arrow {
  font-size: 52rpx; color: #4A90D9; padding: 0 20rpx;
  display: flex; align-items: center; justify-content: center;
}
.week-title-area { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.week-title { font-size: 26rpx; font-weight: 600; color: #333; }
.today-btn {
  font-size: 22rpx; color: #4A90D9; border: 2rpx solid #4A90D9;
  padding: 4rpx 20rpx; border-radius: 20rpx;
}

/* ── 列头 ── */
.grid-header {
  display: flex; background: #fff; flex-shrink: 0;
  border-bottom: 2rpx solid #ddd; position: sticky; top: 0; z-index: 10;
}
.time-gutter-head { width: 80rpx; flex-shrink: 0; }
.day-head {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  padding: 10rpx 0; border-left: 1rpx solid #eee;
}
.day-head.today { background: #EBF4FF; }
.day-week { font-size: 22rpx; color: #888; }
.day-num {
  font-size: 32rpx; font-weight: 700; color: #333;
  width: 52rpx; height: 52rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.day-num.today-num { background: #4A90D9; color: #fff; }

/* ── 滚动区 ── */
.grid-scroll { flex: 1; height: calc(100vh - 280rpx); }
.grid-body { display: flex; position: relative; }

/* 左侧时间刻度 */
.time-gutter { width: 80rpx; flex-shrink: 0; }
.hour-cell {
  height: 100rpx; display: flex; align-items: flex-start;
  justify-content: flex-end; padding-right: 8rpx; box-sizing: border-box;
}
.hour-label { font-size: 18rpx; color: #bbb; margin-top: -12rpx; }

/* 主体格子 */
.grid-main { flex: 1; position: relative; }

/* 横向小时线 */
.bg-lines { position: absolute; inset: 0; pointer-events: none; }
.hour-line {
  height: 100rpx; border-top: 1rpx solid #eee; box-sizing: border-box;
}

/* 竖向列分割线 */
.col-lines {
  position: absolute; inset: 0; display: flex; pointer-events: none;
}
.col-line { flex: 1; border-left: 1rpx solid #e8e8e8; }

/* ── 事件块 ── */
.event-block {
  position: absolute;
  border-radius: 6rpx;
  padding: 4rpx 8rpx;
  overflow: hidden;
  box-sizing: border-box;
  min-height: 30rpx;
  border-left: 6rpx solid rgba(0,0,0,0.18);
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.15);
}
.event-block.ev-pending {
  border-style: dashed;
  border-width: 2rpx;
  border-left-width: 6rpx;
}
.event-block.ev-assigned {
  border-top: 3rpx solid rgba(255,255,255,0.5);
}
.ev-title {
  display: block; font-size: 20rpx; font-weight: 600;
  color: #fff; line-height: 1.3;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.ev-time {
  display: block; font-size: 18rpx; color: rgba(255,255,255,0.85);
}

/* ── 图例 ── */
.legend {
  display: flex; flex-wrap: wrap; gap: 16rpx;
  background: #fff; padding: 16rpx 20rpx;
  border-top: 1rpx solid #eee;
}
.legend-item { display: flex; align-items: center; gap: 8rpx; }
.legend-dot { width: 20rpx; height: 20rpx; border-radius: 4rpx; }
.legend-item text { font-size: 22rpx; color: #555; }

/* ── 操作按钮 ── */
.action-bar {
  display: flex; gap: 12rpx; padding: 16rpx;
  background: #fff; border-top: 1rpx solid #eee;
}
.action-btn {
  flex: 1; height: 76rpx; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; font-weight: 500;
}
.primary  { background: #4A90D9; color: #fff; }
.assigned { background: #5C6BC0; color: #fff; }
.share    { background: #43A047; color: #fff; }

/* ── 成员 ── */
.member-list { padding: 16rpx; }
.member-section-title { font-size: 24rpx; color: #999; padding: 12rpx 8rpx; }
.member-item {
  display: flex; align-items: center; background: #fff;
  border-radius: 16rpx; padding: 20rpx; margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); overflow: hidden;
}
.creator-item { border: 2rpx solid #FFD700; }
.color-bar { width: 8rpx; height: 60rpx; border-radius: 4rpx; margin-right: 16rpx; flex-shrink: 0; }
.member-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; background: #eee; flex-shrink: 0; }
.member-info { flex: 1; margin: 0 16rpx; }
.member-name { font-size: 30rpx; font-weight: 600; color: #222; display: block; }
.member-role { font-size: 22rpx; color: #999; margin-top: 4rpx; display: block; }
.crown { font-size: 36rpx; }
.remove-btn {
  color: #E53935; font-size: 24rpx; padding: 8rpx 18rpx;
  border: 2rpx solid #E53935; border-radius: 20rpx;
}
.danger-zone { margin-top: 40rpx; }
.btn-danger-outline {
  border: 2rpx solid #E53935; color: #E53935; height: 88rpx;
  border-radius: 12rpx; display: flex; align-items: center; justify-content: center; font-size: 30rpx;
}
.empty { text-align: center; padding: 60rpx; color: #bbb; font-size: 28rpx; }
