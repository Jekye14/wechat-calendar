<!-- pages/assigned-event/assigned-event.wxml -->
<view class="page">
  <view class="form-card">
    <view class="field">
      <text class="label required">主题</text>
      <input class="input" placeholder="请输入事件主题" value="{{title}}" bindinput="onTitleInput"/>
    </view>
    <view class="divider"></view>
    <view class="field">
      <text class="label required">开始时间</text>
      <view class="datetime-row">
        <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
          <view class="picker-box">{{startDate}}</view>
        </picker>
        <picker mode="time" value="{{startTime}}" bindchange="onStartTimeChange">
          <view class="picker-box">{{startTime}}</view>
        </picker>
      </view>
    </view>
    <view class="divider"></view>
    <view class="field">
      <text class="label required">结束时间</text>
      <view class="datetime-row">
        <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
          <view class="picker-box">{{endDate}}</view>
        </picker>
        <picker mode="time" value="{{endTime}}" bindchange="onEndTimeChange">
          <view class="picker-box">{{endTime}}</view>
        </picker>
      </view>
    </view>
    <view class="divider"></view>
    <view class="field">
      <text class="label">地点</text>
      <input class="input" placeholder="选填" value="{{location}}" bindinput="onLocationInput"/>
    </view>
    <view class="divider"></view>
    <view class="field">
      <text class="label">内容</text>
      <textarea class="textarea" placeholder="选填" value="{{content}}" bindinput="onContentInput"/>
    </view>
  </view>

  <!-- 选择成员 -->
  <view class="section-title">选择指派成员 *（已选 {{selectedIds.length}} 人）</view>
  <view class="member-card">
    <view wx:if="{{members.length===0}}" class="empty">该日历暂无成员</view>
    <view wx:else>
      <view class="member-item" wx:for="{{members}}" wx:key="id"
        bindtap="toggleMember" data-index="{{index}}">
        <image class="member-avatar" src="{{item.avatar_url}}" mode="aspectFill"/>
        <text class="member-name">{{item.nick_name}}</text>
        <view class="check {{item.selected?'checked':''}}">
          <text wx:if="{{item.selected}}">✓</text>
        </view>
      </view>
    </view>
  </view>

  <view class="tip">指派事件创建后将自动通知被选成员，且无需审批。</view>

  <view class="submit-btn {{submitting?'disabled':''}}" bindtap="submit">
    {{submitting ? '创建中...' : '创建指派事件'}}
  </view>
</view>
